#!/bin/bash
# fixdiff - recount @@ -A,B +C,D @@ headers in a unified diff
#
# LLM-generated diffs often have wrong line counts in hunk headers (off-by-N
# in the new/old line counts, off-by-N in the new-file start line). This
# walks each hunk body, counts the actual context / + / - lines, and
# rewrites the header. New-file starts are recomputed from the running
# offset (additions - deletions accumulated so far).
#
# Usage:
#   fixdiff <file>       in-place rewrite, with <file>.bak backup
#   fixdiff              read stdin, write stdout
#
# Examples:
#   fixdiff engines/0002_sonnet_4_6.diff
#   fixdiff < raw.diff | patch -p1 -o new.js engine.js < /dev/stdin

set -euo pipefail

awk_prog='
function flush() {
  if (in_hunk) {
    nold = ctx + del
    nnew = ctx + add
    nstart = oldStart + offset
    printf("@@ -%d,%d +%d,%d @@%s\n", oldStart, nold, nstart, nnew, trailer)
    for (i = 1; i <= n; i++) print body[i]
    offset += add - del
    fixed++
  }
  ctx = 0; add = 0; del = 0; n = 0; in_hunk = 0
}

/^@@/ {
  flush()
  hdr = $0
  sub(/^@@ /, "", hdr)
  split(hdr, parts, " ")
  o = parts[1]; sub(/^-/, "", o); sub(/,.*/, "", o)
  oldStart = o + 0
  trailer = hdr
  sub(/^[^ ]+ [^ ]+ @@/, "", trailer)
  in_hunk = 1
  next
}

in_hunk {
  c = substr($0, 1, 1)
  if (c == "+") { add++; body[++n] = $0 }
  else if (c == "-") { del++; body[++n] = $0 }
  else if (c == " ") { ctx++; body[++n] = $0 }
  else if (c == "\\") { body[++n] = $0 }   # \ No newline at end of file
  else { flush(); print }
  next
}

{ print }

END {
  flush()
  if (fixed) print "fixdiff: rewrote " fixed " hunk header(s)" > "/dev/stderr"
}
'

if [ $# -eq 0 ]; then
  awk "$awk_prog"
else
  f=$1
  [ -f "$f" ] || { echo "fixdiff: no such file: $f" >&2; exit 1; }
  cp "$f" "$f.bak"
  awk "$awk_prog" "$f.bak" > "$f"
fi
