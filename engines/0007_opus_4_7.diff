< // [Opus 4.7 / 0007] Cheap detection of "side has only pawns and king".
< // Used to guard null-move pruning against zugzwang: NMP is unsafe when the
< // side to move cannot afford to "pass" — i.e. in pure king-pawn endgames
< // where any null search overestimates whose move it actually is. The walk
< // is O(64) but only happens before a possible null move (1x per node at
< // most), so the cost is negligible vs the NMP savings.
< function hasNonPawnMaterial(stm) {
<   const b = g_board;
<   for (let sq = 0; sq < 128; sq++) {
<     if (sq & 0x88) { sq += 7; continue; }
<     const p = b[sq];
<     if (!p || (p & BLACK) !== stm) continue;
<     const t = p & 7;
<     if (t >= KNIGHT && t <= QUEEN) return 1;
<   }
<   return 0;
< }
